<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Top: Logo area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="20dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/logofortal"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fortaleza"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/montserrat_bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFEITURA"
            android:textSize="12sp"
            android:textColor="@color/gray"
            android:letterSpacing="0.15"
            android:fontFamily="@font/montserrat_semibold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudo em um só lugar"
            android:textSize="13sp"
            android:textColor="@color/gray"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Bottom sheet -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_login_sheet"
        android:padding="28dp"
        android:paddingBottom="48dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#66FFFFFF"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp" />

        <EditText
            android:id="@+id/et_cpf"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:hint="CPF (ex: 000.000.000-00)"
            android:textColorHint="#99FFFFFF"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:inputType="phone"
            android:layout_marginBottom="12dp"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/et_cep"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:hint="CEP (ex: 60000-000)"
            android:textColorHint="#99FFFFFF"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:inputType="phone"
            android:imeOptions="actionDone" />

        <Button
            android:id="@+id/btn_enter"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ENTRAR"
            android:background="@drawable/bg_btn_orange"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/btn_no_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Não tenho cadastro"
            android:textColor="#DDFFFFFF"
            android:textSize="14sp"
            android:textAlignment="center"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            android:clickable="true"
            android:focusable="true"
             />

    </LinearLayout>
</LinearLayout>
