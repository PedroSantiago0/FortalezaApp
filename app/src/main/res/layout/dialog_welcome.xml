<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/banner_home"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:contentDescription="Bem-vindo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem-vindo ao app da"
            android:textSize="14sp"
            android:textColor="@color/gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prefeitura de Fortaleza"
            android:textSize="20sp"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/montserrat_bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acesse serviços, registre ocorrências, consulte postos de saúde e muito mais — tudo em um só lugar."
            android:textSize="13sp"
            android:textColor="@color/gray"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_explore"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Explorar o App"
            android:background="@drawable/bg_btn_orange"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>
</LinearLayout>
