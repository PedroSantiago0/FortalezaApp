<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:elevation="4dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/logofortal"
                android:contentDescription="Logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fortaleza"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="@font/montserrat_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREFEITURA"
                    android:textSize="10sp"
                    android:textColor="@color/gray"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="JO"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_chip_teal" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/banner_home"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"
                android:contentDescription="Banner" />
        </androidx.cardview.widget.CardView>

        <!-- Section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVIÇOS"
            android:textSize="11sp"
            android:textColor="@color/gray"
            android:fontFamily="@font/montserrat_bold"
            android:letterSpacing="0.15"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_reclame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/icon1"
                        android:scaleType="fitCenter"
                        android:contentDescription="Reclame" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GERAL"
                        android:textSize="10sp"
                        android:textColor="@color/teal"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECLAME AQUI"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/montserrat_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registre problemas da cidade: buracos, lixo ou iluminação danificada."
                        android:textSize="11sp"
                        android:textColor="@color/gray"
                        android:lineSpacingMultiplier="1.3" />

                    <Button
                        android:id="@+id/btn_reclame"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="CLIQUE AQUI"
                        android:background="@drawable/bg_btn_orange"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginTop="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_iptu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/icon2"
                        android:scaleType="fitCenter"
                        android:contentDescription="IPTU" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FINANCEIRO"
                        android:textSize="10sp"
                        android:textColor="@color/teal"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IPTU &amp; IMPOSTOS"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/montserrat_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consulte e acompanhe seus impostos e taxas municipais, como IPTU."
                        android:textSize="11sp"
                        android:textColor="@color/gray"
                        android:lineSpacingMultiplier="1.3" />

                    <Button
                        android:id="@+id/btn_iptu"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="CLIQUE AQUI"
                        android:background="@drawable/bg_btn_orange"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginTop="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_saude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/icon3"
                        android:scaleType="fitCenter"
                        android:contentDescription="Saúde" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SAÚDE"
                        android:textSize="10sp"
                        android:textColor="@color/teal"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SAÚDE +"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/montserrat_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Postos de atendimento e agente de saúde responsável pela sua região."
                        android:textSize="11sp"
                        android:textColor="@color/gray"
                        android:lineSpacingMultiplier="1.3" />

                    <Button
                        android:id="@+id/btn_saude"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="CLIQUE AQUI"
                        android:background="@drawable/bg_btn_orange"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginTop="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_contatos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/icon4"
                        android:scaleType="fitCenter"
                        android:contentDescription="Contatos" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERVIÇOS PÚBLICOS"
                        android:textSize="10sp"
                        android:textColor="@color/teal"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTATOS PÚBLICOS"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/montserrat_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contatos de secretarias, ouvidoria e outros setores da prefeitura."
                        android:textSize="11sp"
                        android:textColor="@color/gray"
                        android:lineSpacingMultiplier="1.3" />

                    <Button
                        android:id="@+id/btn_contatos"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="CLIQUE AQUI"
                        android:background="@drawable/bg_btn_orange"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginTop="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
