<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FortalezaApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/teal_dark</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="Theme.FortalezaApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logofortal</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/white</item>
        <item name="postSplashScreenTheme">@style/Theme.FortalezaApp</item>
    </style>

    <style name="Theme.FortalezaApp.Gray" parent="Theme.FortalezaApp">
        <item name="android:windowBackground">@color/gray_light</item>
    </style>

    <style name="CardStyle" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="BtnPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
    </style>

    <style name="ChipAction" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/teal</item>
        <item name="android:textColor">@color/teal</item>
        <item name="android:textSize">12sp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
    </style>
</resources>
